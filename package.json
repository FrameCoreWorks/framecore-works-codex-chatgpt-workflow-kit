{
  "name": "framecore-works-codex-workflow-kit",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "FrameCore Works: Creative Workflow Skill Kit for Codex.",
  "license": "Apache-2.0",
  "scripts": {
    "audit:privacy": "node scripts/audit-privacy.mjs",
    "cleanup:appledouble": "node scripts/cleanup-appledouble.mjs",
    "install:dry-run": "node scripts/install.mjs --mode dry-run",
    "onboard:defaults": "node scripts/onboard.mjs --defaults",
    "render:agents": "node scripts/render-agents.mjs",
    "test": "node --test tests/*.test.mjs",
    "validate": "node scripts/validate.mjs",
    "check": "npm run audit:privacy && npm run validate && npm test"
  },
  "engines": {
    "node": ">=20"
  }
}
